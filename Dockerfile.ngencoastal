#    set -eux; \
#    AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws \
#    aws s3 cp s3://ngwpc-data/NWM_Parm_v3.0/domain_hawaii.tar.gz ./; \
#    tar -zxvf domain_hawaii.tar.gz -C /ngen-app/nwm.v3.0.6/parm/ domain_hawaii/geo_em_HI.nc ; \
#    rm -f domain_hawaii.tar.gz
#
#RUN --mount=type=secret,id=aws \
#    set -eux; \
#    AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws \
#    aws s3 cp s3://ngwpc-data/NWM_Parm_v3.0/domain_puertorico.tar.gz ./; \
#    tar -zxvf domain_puertorico.tar.gz -C /ngen-app/nwm.v3.0.6/parm/ domain_puertorico/geo_em_PRVI.nc ; \
#    rm -f domain_puertorico.tar.gz

#build the SCHISM binaries
RUN set -eux; \
    \
    cd /ngen-app/nwm.v3.0.6/sorc/schism/; \
    source ./build_schism_cmake_docker.sh; \
    cd /ngen-app/nwm.v3.0.6/sorc/combine_sink_source; \
    make; \
    cp combine_sink_source ../../exec;\
    cd /ngen-app/nwm.v3.0.6/sorc/combine_hotstart7; \
    make; \
    cp combine_hotstart7 ../../exec; \
    cd /ngen-app/nwm.v3.0.6/sorc/metis_prep; \
    make clean; make; \
    cp metis_prep ../../exec; \
    cd /ngen-app/nwm.v3.0.6/sorc/metis; \
    source ./build_metis_docker.sh; \
    cd -

ENV CONDA_ENVS_PATH=/ngen-app/conda/envs/

ARG CONDA_ENV_NAME=ngen_forcing_coastal
COPY ./ngen-forcing/coastal/environment.yml environment.yaml
RUN set -eux; \
    \
    conda env create --name ${CONDA_ENV_NAME} --file=environment.yaml ; \
    conda clean --all ; \
    rm --force environment.yaml

RUN set -eux; \
    \
    conda init bash

ARG CONDA_ENV_PATH=${CONDA_ENVS_PATH}/${CONDA_ENV_NAME}
ARG OLD_PATH=${PATH}
ENV PATH=${CONDA_ENV_PATH}/bin:${PATH}

ENV PATH=${OLD_PATH}

COPY ./ngen-forcing/ /ngen-app/ngen-forcing/
WORKDIR /ngen-app/

RUN set -eux; \
    \
    rm --force /root/.gitconfig

WORKDIR /
SHELL ["/bin/bash", "-c"]

ENTRYPOINT [ "/bin/bash" ] 
