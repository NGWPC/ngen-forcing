#    aws s3 cp s3://ngwpc-data/NWM_Parm_v3.0/coastal.tar.gz ./; \
#    tar -zxvf coastal.tar.gz -C /ngen-app/nwm.v3.0.6/parm/; \
#    rm -f coastal.tar.gz 
