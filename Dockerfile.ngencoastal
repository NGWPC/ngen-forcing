#    set -eux; \
#    AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws \
#    aws s3 cp s3://ngwpc-data/NWM_Parm_v3.0/domain.tar.gz ./; \
#    tar -zxvf domain.tar.gz -C /ngen-app/nwm.v3.0.6/parm/ domain/geo_em_CONUS.nc ; \
#    rm -f domain.tar.gz
